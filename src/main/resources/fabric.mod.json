{
	"schemaVersion": 1,
	"id": "centered_inventory",
	"version": "${version}",
	"name": "Centered Inventory",
	"description": "Centers the player inventory screen and recipe book layout for Minecraft 1.26.1.",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/centered_inventory/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.example.ExampleMod"
		],
		"client": [
			"com.example.client.ExampleModClient"
		]
	},
	"mixins": [
		"centered_inventory.mixins.json",
		{
			"config": "centered_inventory.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~26.1.1",
		"java": ">=25",
		"fabric-api": "*"
	}
}